# Shipnote environment variables
# Copy this file to `.env.local` for development. Do not commit `.env.local`.
# In production (Docker), pass these via `docker run -e` or a mounted env file.

# ---------------------------------------------------------------------------
# Admin login password.
# In production, set this to a long random string.
# In development, "dev" is fine.
# If unset in the Docker image, Shipnote generates a random password on
# first boot and prints it to the container logs.
# ---------------------------------------------------------------------------
SHIPNOTE_ADMIN_PASSWORD=dev

# ---------------------------------------------------------------------------
# Public URL where Shipnote is reachable. Used in:
#   - email links (confirmation, unsubscribe)
#   - the RSS feed's <link> elements
#   - the widget when it's loaded cross-origin
# Include the protocol. No trailing slash.
# ---------------------------------------------------------------------------
SHIPNOTE_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# SQLite database file path.
# Local dev default: ./data/shipnote.db
# Docker image default: /data/shipnote.db (mount a volume at /data to persist)
# ---------------------------------------------------------------------------
SHIPNOTE_DB_PATH=./data/shipnote.db

# ---------------------------------------------------------------------------
# Session cookie secret. Used to sign the admin session cookie.
# Set this to a long random string in production. A placeholder is fine in
# dev, but the cookie will be invalidated whenever this value changes.
# ---------------------------------------------------------------------------
SHIPNOTE_SESSION_SECRET=dev-secret-change-me-in-production

# ---------------------------------------------------------------------------
# Email notifications (optional).
# If SHIPNOTE_EMAIL_API_KEY is unset, publishing a post still works but no
# emails are sent. Subscribers can still subscribe; they just don't receive
# confirmation or post emails (and the dev server logs them to console).
#
# Provider must be "resend" (default) or "postmark".
# ---------------------------------------------------------------------------
SHIPNOTE_EMAIL_PROVIDER=resend
SHIPNOTE_EMAIL_API_KEY=

# Sender address. Must be on a verified domain in your email provider.
# In dev with Resend, you can use `onboarding@resend.dev` to send to yourself.
SHIPNOTE_EMAIL_FROM=changelog@example.com

# ---------------------------------------------------------------------------
# MCP server (optional).
# If unset, /mcp returns 404 and AI agents cannot draft entries via MCP.
# Set to a long random string to enable. Clients connect to /mcp with this
# value as a bearer token.
# ---------------------------------------------------------------------------
SHIPNOTE_MCP_TOKEN=
